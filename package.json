{
  "name": "apha-apps-perms-case-mgmt-api",
  "version": "0.0.0",
  "description": "apha-apps-perms-case-mgmt-api",
  "main": "src/index.js",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "compose:up": "docker compose -f compose.yml up -d",
    "compose:rm": "docker compose -f compose.yml down --remove-orphans --volumes",
    "docker:dev": "NODE_ENV=development npm run server:watch",
    "dev": "NODE_ENV=development npm run server:watch",
    "dev:debug": "NODE_ENV=development npm run server:debug",
    "format": "prettier --write \"**/*.{cjs,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{cjs,js,json,md}\"",
    "git:pre-commit-hook": "npm run format:check && npm run lint",
    "postinstall": "npm run setup:husky",
    "lint": "run-s lint:js lint:types",
    "lint:js": "eslint --cache --cache-strategy content \"**/*.{cjs,js}\"",
    "lint:fix": "npm run lint -- --fix",
    "lint:types": "tsc --build tsconfig.json",
    "postversion": "git add package.json package-lock.json && git commit -m $npm_package_version",
    "test": "node --no-experimental-require-module ./node_modules/jest/bin/jest.js --coverage --verbose --runInBand",
    "test:watch": "node --no-experimental-require-module ./node_modules/jest/bin/jest.js --watch",
    "server:watch": "nodemon --inspect=0.0.0.0 --ext js,json --legacy-watch ./src",
    "server:debug": "nodemon --inspect-brk=0.0.0.0 --ext js,json --legacy-watch ./src",
    "start": "NODE_ENV=production node --use-strict .",
    "setup:husky": "node -e \"try { (await import('husky')).default() } catch (e) { if (e.code !== 'ERR_MODULE_NOT_FOUND') throw e }\" --input-type module"
  },
  "author": "Defra DDTS",
  "license": "OGL-UK-3.0",
  "dependencies": {
    "@aws-sdk/client-s3": "3.1055.0",
    "@aws-sdk/client-sqs": "3.1055.0",
    "@aws-sdk/credential-providers": "3.1055.0",
    "@azure/identity": "4.13.1",
    "@defra/hapi-tracing": "1.30.0",
    "@elastic/ecs-pino-format": "1.5.0",
    "@hapi/boom": "10.0.1",
    "@hapi/hapi": "21.4.9",
    "@hapi/jwt": "3.2.3",
    "@microsoft/microsoft-graph-client": "3.0.7",
    "aws-embedded-metrics": "4.2.1",
    "aws4": "1.13.2",
    "cacheable-lookup": "7.0.0",
    "compress-pdf": "0.6.3",
    "convict": "6.2.5",
    "convict-format-with-validator": "6.2.0",
    "global-agent": "3.0.0",
    "hapi-pino": "13.0.0",
    "hapi-pulse": "3.0.1",
    "https-proxy-agent": "9.0.0",
    "joi": "18.2.1",
    "mongo-locks": "3.1.2",
    "mongodb": "7.2.0",
    "node-fetch": "3.3.2",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "sharp": "0.34.5",
    "undici": "8.3.0"
  },
  "devDependencies": {
    "@babel/core": "7.29.7",
    "@babel/preset-env": "7.29.7",
    "@shelf/jest-mongodb": "6.0.2",
    "@types/jest": "30.0.0",
    "autoprefixer": "10.5.0",
    "aws-sdk-client-mock": "4.1.0",
    "babel-jest": "30.4.1",
    "babel-plugin-transform-import-meta": "2.3.3",
    "eslint": "10.4.1",
    "husky": "9.1.7",
    "jest": "30.4.2",
    "neostandard": "0.13.0",
    "nodemon": "3.1.14",
    "npm-run-all": "4.1.5",
    "prettier": "3.8.3",
    "typescript": "6.0.3"
  },
  "overrides": {
    "lodash": "4.17.23"
  }
}
